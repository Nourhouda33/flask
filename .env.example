# ─── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=healthcare-ai-secret-change-me

# ─── MySQL XAMPP ──────────────────────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DB=healthcare_ai_platform

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=jwt-healthcare-secret-change-me
JWT_ACCESS_HOURS=8
JWT_REFRESH_DAYS=30

# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120
LLAMA3_MODEL=llama3
QWEN_CODER_MODEL=qwen2.5-coder:7b-instruct
SQLCODER_MODEL=sqlcoder

# ─── Embeddings ───────────────────────────────────────────────────────────────
BIOBERT_MODEL=dmis-lab/biobert-base-cased-v1.2
BIOLORD_MODEL=FremyCompany/BioLORD-2023
EMBEDDING_DIMENSION=768

# ─── FAISS ────────────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=embeddings/faiss_store/healthcare.index
FAISS_METADATA_PATH=embeddings/faiss_store/metadata.json

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4200

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FILE=logs/healthcare_ai.log

# ─── Evaluation ───────────────────────────────────────────────────────────────
EVAL_DATASET_PATH=evaluation/datasets/medical_queries.json
CONFIDENCE_THRESHOLD=0.75
